# Copy this file to `.env.local` for local development.
# Values below are placeholders only. Never commit real secrets.
# For agentic development, prefer disposable/dev-only credentials and resources.
# Placeholder values are enough for scaffold-only checks, but live integrations
# require replacing the relevant values with disposable dev credentials.

# Supabase client-safe values
# Required for: Supabase client setup, auth, database, watchlist, token work
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase server-only values
# Required for: server-side Supabase helpers, protected data access
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# TMDb server-only value
# Required for: TMDb wrapper, search, refresh jobs
TMDB_API_KEY="your-tmdb-api-key"

# Scheduled refresh protection
# Required for: protected cron/release refresh endpoint
CRON_SECRET="replace-with-a-long-random-secret"
